# Deployment configuration — copy to .env and fill in real values
EC2_IP=<your-ec2-ip>
SSH_KEY=~/.ssh/<your-key>.pem
SSH_USER=ubuntu
DB_NAME=procurement_demo
DB_USER=procurement_user
DB_PASSWORD=<your-db-password>
DB_SCHEMA=procurement
DB_PORT=5432

# SAP HANA Cloud (BTP)
HANA_HOST=<your-hana-host>.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=<your-hana-password>
HANA_SCHEMA=PROCUREMENT

# GraphRAG backend: "hana" (default) or "networkx"
GRAPH_BACKEND=hana

# NetworkX backend settings (only needed if GRAPH_BACKEND=networkx)
CSV_DIR=output/csv
GRAPH_PICKLE=output/graph.pkl

# SAP GenAI Hub (via SAP AI Core service key — uses sap-ai-sdk-gen Orchestration V2)
AICORE_AUTH_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com
AICORE_CLIENT_ID=<clientid-from-service-key>
AICORE_CLIENT_SECRET=<clientsecret-from-service-key>
AICORE_RESOURCE_GROUP=default
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com
# Model name uses vendor prefix (e.g. anthropic--claude-4.6-opus, gpt-4o, gemini-2.5-pro)
GENAI_MODEL_NAME=anthropic--claude-4.6-opus
